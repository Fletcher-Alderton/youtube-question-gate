{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fletcher-alderton.github.io/youtube-question-gate/question-sheet.schema.json",
  "title": "YouTube Question Gate Question Sheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "title",
    "questions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]+$",
      "description": "Optional stable sheet identifier. Generated during upload if omitted."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "builtin": {
      "type": "boolean",
      "description": "Reserved for sheets packaged with the extension."
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "answer": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              }
            ],
            "description": "Use a number, a decimal string, a fraction string such as 2/3, or a short exact text answer."
          },
          "tolerance": {
            "type": "number",
            "minimum": 0,
            "maximum": 1000000,
            "description": "Optional numeric tolerance for rounded decimal answers."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            },
            "uniqueItems": true
          },
          "explanation": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    }
  }
}
